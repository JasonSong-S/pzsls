<!-- pages/index/index.wxml -->
<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>正在登录...</text>
  </view>

  <view wx:else class="welcome-card card">
    <view class="welcome-title">欢迎使用课时管理系统</view>
    <view class="welcome-desc">彭州宋量身定制</view>

    <view wx:if="{{!role}}" class="bind-section">
      <view class="bind-tip">您还未绑定学生，请先绑定</view>
      <button class="btn-primary" bindtap="goToBind">绑定学生</button>
    </view>
  </view>
</view>
